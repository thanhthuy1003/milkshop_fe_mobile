<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <include
        android:id="@+id/seller_header"
        layout="@layout/layout_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/seller_header"
        android:layout_above="@id/bottom_navigation_seller">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THỐNG KÊ CỬA HÀNG"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark_blue"
                android:layout_marginBottom="16dp"/>

            <!-- Stats Cards Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/primary_light_blue">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đơn hàng"
                            android:textColor="@color/black"/>
                        <TextView
                            android:id="@+id/tvOrderCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="120"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark_blue"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/primary_light_blue">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doanh thu"
                            android:textColor="@color/black"/>
                        <TextView
                            android:id="@+id/tvRevenue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5.2M"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark_blue"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <Button
                android:id="@+id/btnManageProducts"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:text="QUẢN LÝ SẢN PHẨM"
                android:backgroundTint="@color/primary_blue"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="12dp"/>
                
            <Button
                android:id="@+id/btnManageOrders"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:text="QUẢN LÝ ĐƠN HÀNG"
                android:backgroundTint="@color/primary_blue"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/bottom_navigation_seller"
        layout="@layout/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
